#include "resource.h"
#include "Shaders\\ShaderResourceIds.h"
#include <windows.h>

// Application icons. The icon assigned the lowest numerical resource ID
// (IDI_CASSO_SILHOUETTE) is what Windows Explorer displays for
// Casso.exe. All five are embedded so callers can pick a different
// motif at runtime via LoadIcon if desired.
IDI_CASSO_SILHOUETTE         ICON "..\\Resources\\Icons\\Casso-0-silhouette.ico"
IDI_CASSO_SILHOUETTE_ACCENT  ICON "..\\Resources\\Icons\\Casso-4-silhouette-accent.ico"
IDI_CASSO_SILHOUETTE_RAINBOW ICON "..\\Resources\\Icons\\Casso-1-silhouette-rainbow.ico"
IDI_CASSO_FLAT_COLOR_HEAD    ICON "..\\Resources\\Icons\\Casso-2-flat-color-head.ico"
IDI_CASSO_PHOTOREAL          ICON "..\\Resources\\Icons\\Casso-3-photoreal.ico"

// Embedded default machine configs (extracted to Machines/<name>/<name>.json
// on first run by AssetBootstrap::EnsureMachineConfigs). Sources live under
// Resources/ which is tracked; the runtime Machines/ tree is .gitignored
// because every file in it is either extracted from these resources or
// downloaded by AssetBootstrap.
IDR_MACHINE_APPLE2      RCDATA "..\\Resources\\Machines\\Apple2\\Apple2.json"
IDR_MACHINE_APPLE2PLUS  RCDATA "..\\Resources\\Machines\\Apple2Plus\\Apple2Plus.json"
IDR_MACHINE_APPLE2E     RCDATA "..\\Resources\\Machines\\Apple2e\\Apple2e.json"

// Embedded built-in theme files (extracted on first run by
// AssetBootstrap::EnsureThemes — see Casso/AssetBootstrap.cpp).
// Sources live under Resources/Themes/<Name>/; the runtime
// Themes/ tree is .gitignored.
IDR_THEME_SKEUO_THEME_JSON         RCDATA "..\\Resources\\Themes\\Skeuomorphic\\theme.json"
IDR_THEME_SKEUO_FONT_TTF           RCDATA "..\\Resources\\Themes\\Skeuomorphic\\fonts\\Inter-Regular.ttf"
IDR_THEME_SKEUO_FONT_OFL           RCDATA "..\\Resources\\Themes\\Skeuomorphic\\fonts\\OFL.txt"
IDR_THEME_SKEUO_FONT_TODO          RCDATA "..\\Resources\\Themes\\Skeuomorphic\\fonts\\TODO_FONTS.md"

IDR_THEME_DARK_THEME_JSON          RCDATA "..\\Resources\\Themes\\DarkModern\\theme.json"
IDR_THEME_DARK_FONT_TTF            RCDATA "..\\Resources\\Themes\\DarkModern\\fonts\\Inter-Regular.ttf"
IDR_THEME_DARK_FONT_OFL            RCDATA "..\\Resources\\Themes\\DarkModern\\fonts\\OFL.txt"
IDR_THEME_DARK_FONT_TODO           RCDATA "..\\Resources\\Themes\\DarkModern\\fonts\\TODO_FONTS.md"

IDR_THEME_RETRO_THEME_JSON         RCDATA "..\\Resources\\Themes\\RetroTerminal\\theme.json"
IDR_THEME_RETRO_FONT_TTF           RCDATA "..\\Resources\\Themes\\RetroTerminal\\fonts\\VT323-Regular.ttf"
IDR_THEME_RETRO_FONT_OFL           RCDATA "..\\Resources\\Themes\\RetroTerminal\\fonts\\OFL.txt"
IDR_THEME_RETRO_FONT_TODO          RCDATA "..\\Resources\\Themes\\RetroTerminal\\fonts\\TODO_FONTS.md"

// Embedded CRT HLSL sources (compiled at runtime by CrtPostProcess).
IDR_HLSL_BRIGHTNESS      RCDATA "Shaders\\CRT\\brightness.hlsl"
IDR_HLSL_SCANLINES       RCDATA "Shaders\\CRT\\scanlines.hlsl"
IDR_HLSL_BLOOM_H         RCDATA "Shaders\\CRT\\bloom_h.hlsl"
IDR_HLSL_BLOOM_V         RCDATA "Shaders\\CRT\\bloom_v.hlsl"
IDR_HLSL_BLOOM_COMPOSITE RCDATA "Shaders\\CRT\\bloom_composite.hlsl"
IDR_HLSL_COLOR_BLEED     RCDATA "Shaders\\CRT\\color_bleed.hlsl"
IDR_HLSL_PERSISTENCE     RCDATA "Shaders\\CRT\\persistence.hlsl"
IDR_HLSL_GAMMA           RCDATA "Shaders\\CRT\\gamma.hlsl"
IDR_HLSL_COPY            RCDATA "Shaders\\CRT\\copy.hlsl"
IDR_HLSL_SETTINGS_GAUSSIAN_H RCDATA "Shaders\\Settings\\gaussian_h.hlsl"
IDR_HLSL_SETTINGS_GAUSSIAN_V RCDATA "Shaders\\Settings\\gaussian_v.hlsl"
IDR_HLSL_SETTINGS_COMPOSE    RCDATA "Shaders\\Settings\\settings_compose.hlsl"

// Keyboard Accelerator Table
IDR_ACCELERATOR ACCELERATORS
BEGIN
    "R",            IDM_MACHINE_RESET,      VIRTKEY, CONTROL, SHIFT
    "P",            IDM_MACHINE_POWERCYCLE, VIRTKEY, CONTROL, SHIFT
    VK_PAUSE,       IDM_MACHINE_PAUSE,      VIRTKEY
    VK_F11,         IDM_MACHINE_STEP,       VIRTKEY
    VK_RETURN,      IDM_VIEW_FULLSCREEN,    VIRTKEY, ALT
    "0",            IDM_VIEW_RESET_SIZE,    VIRTKEY, CONTROL
    "1",            IDM_DISK_INSERT1,       VIRTKEY, CONTROL
    "2",            IDM_DISK_INSERT2,       VIRTKEY, CONTROL
    VK_F1,          IDM_HELP_KEYMAP,        VIRTKEY
    "D",            IDM_VIEW_DISK2_DEBUG,  VIRTKEY, CONTROL, SHIFT
    "I",            IDM_VIEW_INPUT_DEBUG, VIRTKEY, CONTROL, SHIFT
    VK_OEM_COMMA,   IDM_VIEW_SETTINGS,      VIRTKEY, CONTROL
    "J",            IDM_MACHINE_ARROWS_JOYSTICK, VIRTKEY, CONTROL, SHIFT
END

// Version Information
VS_VERSION_INFO VERSIONINFO
    FILEVERSION     0,9,0,0
    PRODUCTVERSION  0,9,0,0
    FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
    FILEFLAGS       VS_FF_DEBUG
#else
    FILEFLAGS       0
#endif
    FILEOS          VOS_NT_WINDOWS32
    FILETYPE        VFT_APP
    FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "\0"
            VALUE "FileDescription",  "Casso Apple ][ Emulator\0"
            VALUE "FileVersion",      "0.9.0.0\0"
            VALUE "InternalName",     "Casso\0"
            VALUE "OriginalFilename", "Casso.exe\0"
            VALUE "ProductName",      "Casso\0"
            VALUE "ProductVersion",   "0.9.0.0\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
