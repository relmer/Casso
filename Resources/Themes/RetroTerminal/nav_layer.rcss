body.navlayer
{
    width: 100%;
    height: 28dp;
    background-color: #001a00;
    color: #33ff66;
    font-family: monospace;
    font-size: 13dp;
    border-bottom: 1dp #1d8a33;
    top: 32dp;
}

.nav-strip { display: block; height: 28dp; padding-left: 8dp; }

.nav-item
{
    display: inline-block;
    padding: 6dp 10dp;
    color: #33ff66;
}

.nav-item:hover { color: #ffbf00; }
