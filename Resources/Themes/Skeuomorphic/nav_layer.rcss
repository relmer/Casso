body.navlayer
{
    width: 100%;
    height: 28dp;
    background-color: #efe6d2;
    color: #2a2418;
    font-family: sans-serif;
    font-size: 12dp;
    border-bottom: 1dp #b09a76;
    top: 32dp;
}

.nav-strip { display: block; height: 28dp; padding-left: 8dp; }

.nav-item
{
    display: inline-block;
    padding: 6dp 12dp;
    color: #2a2418;
}

.nav-item:hover { background-color: #d9cdb6; }
