body.navlayer
{
    width: 100%;
    height: 28dp;
    background-color: #1c2027;
    color: #d8dde6;
    font-family: sans-serif;
    font-size: 12dp;
    border-bottom: 1dp #2a323e;
    top: 32dp;
}

.nav-strip { display: block; height: 28dp; padding-left: 8dp; }

.nav-item { display: inline-block; padding: 6dp 12dp; color: #d8dde6; }

.nav-item:hover { background-color: #2a323e; color: #4cc9ff; }
