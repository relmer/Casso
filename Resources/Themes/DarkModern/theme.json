{
    "$cassoThemeVersion": 1,
    "$cassoBuiltIn":      true,
    "name":               "DarkModern",
    "author":             "Casso",
    "description":        "Sleek dark UI with glowing LED accents. Win11 Mica backdrop.",
    "entryDocuments": {
        "titleBar":     "title_bar.rml",
        "navLayer":     "nav_layer.rml",
        "settings":     "settings.rml",
        "driveWidgets": "drive_widgets.rml"
    },
    "crtDefaults": {
        "brightness": 1.05,
        "scanlines":  { "enabled": true,  "intensity": 0.25 },
        "bloom":      { "enabled": true,  "radius": 1.5, "strength": 0.5 },
        "colorBleed": { "enabled": false, "width":  0.0 }
    },
    "useMicaBackdrop": true
}
