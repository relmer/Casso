{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casso/schemas/theme-metadata.schema.json",
  "title": "ThemeMetadata",
  "description": "theme.json metadata file shipped with every theme. See specs/007-ui-overhaul/data-model.md § Theme.",
  "type": "object",
  "required": ["$cassoThemeVersion", "name"],
  "additionalProperties": false,
  "properties": {
    "$cassoThemeVersion": { "type": "integer", "minimum": 1 },
    "name":               { "type": "string", "minLength": 1, "maxLength": 64 },
    "author":             { "type": "string", "maxLength": 128 },
    "description":        { "type": "string", "maxLength": 512 },
    "entryDocuments": {
      "type": "object",
      "description": "Per-element RML overrides. Any entry omitted falls back to Themes/_shared/<entry>.rml.",
      "additionalProperties": false,
      "properties": {
        "titleBar":     { "type": "string", "pattern": "\\.rml$" },
        "navLayer":     { "type": "string", "pattern": "\\.rml$" },
        "settings":     { "type": "string", "pattern": "\\.rml$" },
        "driveWidgets": { "type": "string", "pattern": "\\.rml$" }
      }
    },
    "crtDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "brightness": { "type": "number", "minimum": 0.0, "maximum": 2.0 },
        "scanlines": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":   { "type": "boolean" },
            "intensity": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        "bloom": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled":  { "type": "boolean" },
            "radius":   { "type": "number", "minimum": 0.0, "maximum": 4.0 },
            "strength": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        "colorBleed": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "width":   { "type": "number", "minimum": 0.0, "maximum": 4.0 }
          }
        }
      }
    },
    "useMicaBackdrop": { "type": "boolean" }
  }
}
